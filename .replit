modules = ["web", "python-3.11"]
[agent]
expertMode = true
integrations = ["python_anthropic_ai_integrations:1.0.0", "sendgrid:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["uv", "run", "gunicorn", "--bind=0.0.0.0:5000", "--workers=2", "--timeout=120", "server:app"]
build = ["uv", "sync"]
